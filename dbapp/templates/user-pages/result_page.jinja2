{% extends "layout.jinja2" %}
{% block content %}
<h2 class="title">アップロード結果</h2>
<table>
    <thead>
        <th>結果</th>
        {% if result["status"] == "failed" %}
        <th>理由</th>
        {% endif %}
        {% if result["status"] == "success" %}
        <th>ページ</th>
        {% endif %}
    </thead>
    <tbody>
        <tr>
            <td>{{ result["status"] }}</td>
            {% if result["status"] == "failed" %}
            <td>{{ result["reason"] }}</td>
            {% endif %}
            {% if result["status"] == "success" %}
            <td><a href="{{ url_for('user_bp.file', id = result['id']) }}">{{ result['name'] }}</a></td>
            {% endif %}
        </tr>
    </tbody>
    <a href="{{ url_for('studies_bp.edit_study', id = result['parent_id']) }}">研究グループの編集に戻る</a>
</table>
{% endblock %}